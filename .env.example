# Supabase project settings — dashboard → Project Settings → API
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# anon / public key — respects Row Level Security (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — bypasses Row Level Security. Server-only secret.
# NEVER prefix this with NEXT_PUBLIC_ and never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=
